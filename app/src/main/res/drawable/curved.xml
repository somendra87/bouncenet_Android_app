<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Main Green Pill Accent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22C55E" />
            <corners
                android:topLeftRadius="50dp"
                android:topRightRadius="50dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

    <!-- Slight highlight for softer look (optional) -->
    <item android:top="2dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#4ADE80" />
            <corners
                android:topLeftRadius="46dp"
                android:topRightRadius="46dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

</layer-list>