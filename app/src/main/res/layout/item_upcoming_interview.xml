<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/interviewItemCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="4dp"
    android:layout_marginStart="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="22dp"
    android:elevation="2dp"
    app:strokeColor="@color/stroke_color"
    app:strokeWidth="1dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dateTitle"
            android:layout_width="68dp"
            android:layout_height="68dp"
            app:cardBackgroundColor="#F7F9Fc"
            app:cardCornerRadius="18dp"
            android:elevation="0dp"
            app:strokeColor="#E9EEF5"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                >
                <TextView
                    android:id="@+id/txtMonthTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAY"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    />

                <TextView
                    android:id="@+id/txtDayTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="11"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtInterviewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Product Analysis"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@+id/dateTitle"
            app:layout_constraintTop_toTopOf="@id/dateTitle"
            app:layout_constraintEnd_toStartOf="@id/statusChip"
            />

        <TextView
            android:id="@+id/txtCompanyTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Innovatech Pvt. Ltd."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:maxLines="1"
            app:layout_constraintTop_toBottomOf="@id/txtInterviewTitle"
            app:layout_constraintStart_toStartOf="@id/txtInterviewTitle"
            app:layout_constraintEnd_toStartOf="@+id/statusChip"
            />

        <!-- ================================================= -->
        <!-- STATUS CHIP -->
        <!-- ================================================= -->

        <TextView
            android:id="@+id/txtSchedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="11:00 AM - Round 1"
            android:textColor="#9AA6B6"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtCompanyTextView"
            app:layout_constraintStart_toStartOf="@id/txtCompanyTextView"
            app:layout_constraintEnd_toEndOf="parent"
            />
        <!-- ================================================= -->
        <!-- STATUS CHIP -->
        <!-- ================================================= -->

        <TextView
            android:id="@+id/statusChip"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_status_chip"
            android:gravity="center"
            android:minWidth="76dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Online"
            android:textColor="@color/primary_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/dateTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>