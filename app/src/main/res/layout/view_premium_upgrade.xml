<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/premiumUpgradeCard"
    android:layout_marginStart="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="@color/premium_card_background"
    app:cardCornerRadius="28dp"
    android:elevation="1dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingEnd="0dp"
        >

        <!-- ================================================= -->
        <!-- DECORATIVE CIRCLE -->
        <!-- ================================================= -->
        <ImageView
            android:id="@+id/premiumUpgradeDecoCircleView"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:background="@drawable/ic_premium_decor"
            android:alpha="0.25"
            android:rotation="12"
            android:scaleType="center"

            android:translationX="10dp"
            android:translationY="20dp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />
        <!-- ================================================= -->
        <!-- Title -->
        <!-- ================================================= -->
        <TextView
            android:id="@+id/premiumUpgradeTitleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Unlock more opportunities"
            android:textColor="@color/premium_orange"
            android:textSize="20sp"
            android:textStyle="bold"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />


        <!-- ================================================= -->
        <!-- DESCRIPTION -->
        <!-- ================================================= -->
        <TextView
            android:id="@+id/premiumUpgradeDescriptionTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="3dp"
            android:text="Upgrade to BouncePlus and get AI Auto-Applu, mentor support and faster referal"
            android:textColor="@color/premium_text"
            android:textSize="17sp"
            app:layout_constraintTop_toBottomOf="@id/premiumUpgradeTitleTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/premiumUpgradeDecoCircleView"
            />

        <!-- ================================================= -->
        <!-- CTA Button -->
        <!-- ================================================= -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/premiumUpgradeActionButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:text="Upgrade Now →"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:backgroundTint="@color/premium_orange"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/premiumUpgradeDescriptionTextView"
            app:layout_constraintStart_toStartOf="parent"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>