<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="4dp"
    app:cardCornerRadius="24dp"
    android:elevation="4dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        >

        <TextView
            android:id="@+id/textQuote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❝"
            android:textSize="42dp"
            android:textColor="#D1E4FF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/textTestimonialDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="italic"
            android:text="@string/testimonial_description"
            app:layout_constraintTop_toBottomOf="@id/textQuote"
            app:layout_constraintStart_toStartOf="@id/textQuote"
            />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/testimonialCardImageView"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/happy_woman_image_no_bg"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/textTestimonialDescription"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/nameOfMember"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Sarah Smith"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="@id/testimonialCardImageView"
            app:layout_constraintStart_toEndOf="@id/testimonialCardImageView"
            app:layout_constraintTop_toTopOf="@id/testimonialCardImageView"
            app:layout_constraintVertical_bias="0.275" />

        <TextView
            android:id="@+id/memberDesignation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Manager"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/nameOfMember"
            app:layout_constraintStart_toStartOf="@id/nameOfMember"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>