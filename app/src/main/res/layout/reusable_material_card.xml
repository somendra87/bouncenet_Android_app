<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardCornerRadius="20dp"
        android:elevation="8dp"
        app:cardBackgroundColor="@color/primary_blue"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            >
            <ImageView
                android:id="@+id/reusableCardImage"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/groups_24dp_filled"
                android:backgroundTint="@color/primary_blue"
                app:tint = "@color/feature_blue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                />

            <TextView
                android:id="@+id/reusableCardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Community"
                android:textSize="21dp"
                android:layout_marginStart="18dp"
                android:textColor="@color/white"
                app:layout_constraintStart_toEndOf="@id/reusableCardImage"
                app:layout_constraintTop_toTopOf="@id/reusableCardImage"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="That Cares"
                android:textSize="10sp"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/reusableCardTitle"
                app:layout_constraintStart_toStartOf="@id/reusableCardTitle"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>