<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ================================================= -->
    <!-- SECTION TITLE -->
    <!-- ================================================= -->
    <TextView
        android:id="@+id/upcomingInterviewSectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18sp"
        android:layout_marginTop="28sp"
        android:text="Upcoming Interviews"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <!-- ================================================= -->
    <!-- VIEW ALL -->
    <!-- ================================================= -->
    <TextView
        android:id="@+id/upcomingInterviewSectionViewALl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:text="View All"
        android:textColor="@color/primary_blue"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/upcomingInterviewSectionTitle"
        app:layout_constraintBottom_toBottomOf="@+id/upcomingInterviewSectionTitle"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <!-- ================================================= -->
    <!-- RECYCLER VIEW -->
    <!-- ================================================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/upcomingInterviewRecyclerView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/upcomingInterviewSectionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>