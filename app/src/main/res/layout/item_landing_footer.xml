<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp"
    android:background="#F8FAFC"
    android:layout_marginTop="10dp"
    >

    <View
        android:id="@+id/upperLineDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/drawable_divider"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/landingFooterLogo"
        />
    <ImageView
        android:id="@+id/landingFooterLogo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/bouncenet_logo_no_bg"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/landingFooterBrandName"
        />

    <TextView
        android:id="@+id/landingFooterBrandName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BounceNet"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="22sp"
        app:layout_constraintStart_toEndOf="@+id/landingFooterLogo"
        app:layout_constraintBottom_toBottomOf="@id/landingFooterLogo"
        app:layout_constraintTop_toTopOf="@id/landingFooterLogo"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footerNavigationContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/landingFooterBrandName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        >
        <TextView
            android:id="@+id/footerTvCommunityFund"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Community Fund"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_chainStyle="spread"
            />

        <TextView
            android:id="@+id/footerTvJobs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jobs"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/footerTvCommunityFund"
            app:layout_constraintEnd_toStartOf="@+id/footerTvResources"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <TextView
            android:id="@+id/footerTvResources"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resources"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/footerTvJobs"
            app:layout_constraintEnd_toStartOf="@+id/footerTvAboutUs"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <TextView
            android:id="@+id/footerTvAboutUs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About Us"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/footerTvResources"
            app:layout_constraintEnd_toEndOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/lowelineDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/drawable_divider"
        app:layout_constraintTop_toBottomOf="@id/footerNavigationContainer"
        android:layout_marginTop="16dp"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footerTermsOfServiceNavigationContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/lowelineDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        >
        <TextView
            android:id="@+id/footerPrivacyPolicy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy Policy"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            />

        <TextView
            android:id="@+id/footerTermsOfService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terms of Service"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/footerPrivacyPolicy"
            app:layout_constraintEnd_toStartOf="@+id/footerContactSupport"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <TextView
            android:id="@+id/footerContactSupport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Support"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/footerTermsOfService"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2026 BounceNet.All Rights Reserved."
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/footerTermsOfServiceNavigationContainer"
        />

</androidx.constraintlayout.widget.ConstraintLayout>