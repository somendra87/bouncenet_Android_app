<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileCompletenessCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/stroke_color"
    app:strokeWidth="2dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding = "20dp"
        >

        <!-- ================================================= -->
        <!-- TITLE -->
        <!-- ================================================= -->
        <TextView
            android:id="@+id/profileCompletenessTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Completeness"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />

        <!-- ================================================= -->
        <!-- Percentage -->
        <!-- ================================================= -->
        <TextView
            android:id="@+id/profileCompletenessPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80%"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@+id/profileCompletenessTitle"
            app:layout_constraintBottom_toBottomOf="@+id/profileCompletenessTitle"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <!-- ================================================= -->
        <!-- Progress Bar -->
        <!-- ================================================= -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/profileProgressBarIndicator"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="18dp"
            android:progress="80"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp"
            app:indicatorColor="@color/primary_blue"
            app:trackColor="@color/track_color"
            app:layout_constraintTop_toBottomOf="@+id/profileCompletenessTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <!-- ================================================= -->
        <!-- Description -->
        <!-- ================================================= -->
        <TextView
            android:id="@+id/profileCompletenessDescriptionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Complete your profile to unlock more opportunities."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintTop_toBottomOf="@id/profileProgressBarIndicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <!-- ================================================= -->
        <!-- Action -->
        <!-- ================================================= -->

        <TextView
            android:id="@+id/profileCompletenessActionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Complete Now →"
            android:textColor="@color/primary_blue"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/profileCompletenessDescriptionText"
            app:layout_constraintStart_toStartOf="parent"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>