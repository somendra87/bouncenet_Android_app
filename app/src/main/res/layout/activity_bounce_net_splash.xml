<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splashscreen_bg"
    tools:context=".activities.BounceNetSplashActivity">

    <ImageView
        android:id="@+id/bnSplashLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/bn3dimage_no_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Bouncenet Splash Screen"
        />

    <TextView
        android:id="@+id/bnTxtLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BounceNet"
        android:textColor="@color/primary_blue"
        android:textStyle="bold"
        android:textSize="48sp"
        android:fontFamily="sans-serif"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@+id/bnSplashLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>