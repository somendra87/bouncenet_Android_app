<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="28dp"
    android:clipToPadding="false">

    <!--Profile pictures container-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profilePictureContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        >
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profilePictureFirst"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/avatar3_nobg"
            android:elevation="8dp"
            app:civ_border_overlay="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <!-- Profile 2 -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profilePictureSecond"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/avatar3_nobg"
            android:elevation="10dp"
            app:civ_border_overlay="true"
            app:layout_constraintStart_toEndOf="@id/profilePictureFirst"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="-26dp"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Profile 2 -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profilePictureThird"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/avatar3_nobg"
            android:elevation="10dp"
            app:civ_border_overlay="true"
            app:layout_constraintStart_toEndOf="@id/profilePictureSecond"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="-26dp"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <TextView
            android:id="@+id/tvMembersCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10,000+ members"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary_dark"
            android:layout_marginStart="40dp"
            app:layout_constraintStart_toEndOf="@id/profilePictureSecond"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/profilePictureSecond"
            />

        <TextView
            android:id="@+id/tvMembersSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="recovering and thriving together"
            app:layout_constraintStart_toStartOf="@id/tvMembersCount"
            app:layout_constraintTop_toBottomOf="@id/tvMembersCount"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>