<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/planFeatureTickImage"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_check_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/planFeatureTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14.5sp"
        android:textColor="@color/text_primary"
        android:text="Feature 1"
        android:lineSpacingExtra="2dp"
        app:layout_constraintStart_toEndOf="@id/planFeatureTickImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/planFeatureTickImage"
        android:layout_marginStart="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>