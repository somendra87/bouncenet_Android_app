<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/innerConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/white"
    android:elevation="6dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp">
    <!-- 1. Logo Section (Left) -->
    <ImageView
        android:id="@+id/imgGlobalLogo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/bouncenet_logo_no_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <!-- Slot B: User Avatar (Left - Hidden by default) -->
    <ImageView
        android:id="@+id/imgTopBarAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:visibility="gone"
        android:background="@drawable/bg_circle"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Slot C: Title or Name (Center/Left) -->
    <TextView
        android:id="@+id/txtTopBarTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="BounceNet"
        android:textColor="@color/brand_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/imgGlobalLogo"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Primary Action Button (Right) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGlobalPrimary"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Now"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/primary_blue"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 3. Secondary Action Text (Right of Primary) -->
    <TextView
        android:id="@+id/txtGlobalSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Log in"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:background="@drawable/btn_background"
        app:layout_constraintBottom_toBottomOf="@id/btnGlobalPrimary"
        app:layout_constraintEnd_toStartOf="@id/btnGlobalPrimary"
        app:layout_constraintTop_toTopOf="@id/btnGlobalPrimary" />

</androidx.constraintlayout.widget.ConstraintLayout>