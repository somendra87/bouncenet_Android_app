<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp"
            >

            <!-- Hero Image -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/signUpHeroImage"
                android:layout_width="0dp"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                android:src="@drawable/sign_up_hero_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/signUpFormCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_constraintTop_toBottomOf="@+id/signUpHeroImage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                >

                <!--Form Fields-->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/background_light"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="16dp"
                    >

                    <TextView
                        android:id="@+id/signUpHeading"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textSize="32sp"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/brand_blue"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_google"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:text="Continue with Google"
                        app:icon="@drawable/ic_google"
                        app:iconGravity="start"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/signUpHeading"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_linkedIn"
                        app:layout_constraintHorizontal_weight="1"
                        />

                    <!--First Name -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_linkedIn"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="Continue with LinkedIn"
                        app:icon="@drawable/ic_linkedin"
                        app:iconGravity="start"
                        android:layout_marginStart="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_weight="1"
                        app:layout_constraintStart_toEndOf="@id/btn_google"
                        app:layout_constraintTop_toBottomOf="@id/signUpHeading"
                        />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInpLayoutFullName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:startIconDrawable="@drawable/baseline_person_24_filled"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:layout_constraintTop_toBottomOf="@id/btn_google"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"

                        >
                        
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Name"
                            />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!--Email Address -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInpLayoutEmailAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:startIconDrawable="@drawable/outline_stacked_email_24_filled"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:layout_constraintTop_toBottomOf="@id/textInpLayoutFullName"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmailAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mobile -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInpMobile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_marginTop="8dp"
                        app:startIconDrawable="@drawable/outline_mobile_2_24_filled"
                        app:layout_constraintTop_toBottomOf="@id/textInpLayoutEmailAddress"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMobile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:hint="Mobile Number (+91)"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!--Password-->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInpLayoutPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:endIconMode="password_toggle"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:layout_constraintTop_toBottomOf="@id/textInpMobile"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Password"
                            android:inputType="textPassword"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!--Password-->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInpLayoutConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:endIconMode="password_toggle"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:layout_constraintTop_toBottomOf="@id/textInpLayoutPassword"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        >

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Confirm Password"
                            android:inputType="textPassword"
                            />

                    </com.google.android.material.textfield.TextInputLayout>


                    <!--Password Strength-->
                    <TextView
                        android:id="@+id/tvPasswordStrength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password Strength : Medium"
                        android:textColor="@color/accent_orange"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/textInpLayoutConfirmPassword"
                        app:layout_constraintStart_toStartOf="parent"
                        />

                    <CheckBox
                        android:id="@+id/signUpTermsAndConditionCheckBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="I agree to the term of use and Privacy Policy"
                        android:textColor="@color/text_primary"
                        android:checked="false"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/tvPasswordStrength"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        />

                    <!--Create Account Button-->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreateAccount"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:textSize="16sp"
                        android:text="Create My Account"
                        android:layout_marginTop="8dp"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:layout_constraintTop_toBottomOf="@id/signUpTermsAndConditionCheckBox"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        />

                    <!-- Inside the same ConstraintLayout as btnCreateAccount -->
                    <ProgressBar
                        android:id="@+id/signUpProgressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:layout_constraintTop_toTopOf="@id/btnCreateAccount"
                        app:layout_constraintBottom_toBottomOf="@id/btnCreateAccount"
                        app:layout_constraintStart_toStartOf="@id/btnCreateAccount"
                        app:layout_constraintEnd_toEndOf="@id/btnCreateAccount" />


                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/signUpFormCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verified &amp; Safe"
                    android:drawableStart="@drawable/ic_verified"
                    android:drawablePadding="6dp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy First"
                    android:layout_marginStart="32dp"
                    android:drawableStart="@drawable/ic_privacy"
                    android:drawablePadding="6dp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>